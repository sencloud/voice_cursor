# ─────────────────────────────────────────────
#  Model / large binary files
#  (Whisper model.bin ≈ 1.5 GB — exceeds GitHub's 100 MB limit)
# ─────────────────────────────────────────────
resources/whisper-*/model.bin
resources/whisper-*/ggml-*.bin
*.bin

# ─────────────────────────────────────────────
#  Runtime / user data
# ─────────────────────────────────────────────
*.wav
*.mp3
*.ogg
*.flac
temp/
tmp/
logs/
*.log

# App config stored in user home directory — not part of the repo
# (~/.voice_cursor/config.json is written at runtime)

# ─────────────────────────────────────────────
#  IDE & editor
# ─────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────
#  Windows
# ─────────────────────────────────────────────
desktop.ini
$RECYCLE.BIN/

# ─────────────────────────────────────────────
#  Secrets / credentials  (never commit these)
# ─────────────────────────────────────────────
.env
.env.*
!.env.example
secrets.json
api_keys.json
